.page {
  padding: 20rpx;
}

/* ====== Check-in Card ====== */

.checkin-card {
  background: #FFFBF7;
  border-radius: 28rpx;
  padding: 40rpx 20rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(180,140,120,0.12);
  margin-bottom: 24rpx;
  position: relative;
  overflow: visible;
}

/* Cat ears on top of card */
.cat-ears {
  position: absolute;
  top: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 40rpx;
}

.cat-ear {
  position: absolute;
  top: 0;
  width: 0;
  height: 0;
  border-left: 24rpx solid transparent;
  border-right: 24rpx solid transparent;
  border-bottom: 36rpx solid #FFFBF7;
  filter: drop-shadow(0 -2rpx 4rpx rgba(180,140,120,0.08));
}

.cat-ear.ear-left {
  left: 8rpx;
  transform: rotate(-8deg);
}

.cat-ear.ear-right {
  right: 8rpx;
  transform: rotate(8deg);
}

.checkin-card-header {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
  text-align: center;
}

.checkin-card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5D4037;
  margin-bottom: 6rpx;
}

.checkin-card-sub {
  font-size: 24rpx;
  color: #BCAAA4;
}

/* ====== Horizontal Scroll Strip ====== */

.task-strip {
  width: 100%;
  white-space: nowrap;
}

.strip-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 8rpx 12rpx;
}

/* ====== Mini Card ====== */

.mini-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 164rpx;
  flex-shrink: 0;
  background: #FFFBF7;
  border: 2rpx solid #F0E8E0;
  border-radius: 22rpx;
  padding: 24rpx 14rpx 18rpx;
  position: relative;
  transition: transform 0.15s, box-shadow 0.15s;
  white-space: normal;
  box-shadow: 0 2rpx 8rpx rgba(180,140,120,0.04);
}

.mini-card:active {
  transform: scale(0.94);
}

.mini-card.checked {
  background: linear-gradient(180deg, #FFF5EC 0%, #FFF2EC 100%);
  border-color: #F0C8B0;
  box-shadow: 0 4rpx 16rpx rgba(232,144,92,0.12);
}

.mini-card.done {
  background: linear-gradient(180deg, #FFFBF7 0%, #FFF8E1 100%);
  border-color: #FFE0B2;
}

.mini-emoji {
  font-size: 54rpx;
  margin-bottom: 10rpx;
}

.mini-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 10rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Fish bone progress bar */
.fish-bone-bar {
  width: 100%;
  height: 8rpx;
  background: #F5F0EB;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.fish-bone-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFB74D, #E8905C);
  border-radius: 10rpx;
  transition: width 0.4s ease;
}

.mini-card.checked .fish-bone-fill {
  background: linear-gradient(90deg, #E8905C, #F0B898);
}

.mini-card.done .fish-bone-fill {
  background: linear-gradient(90deg, #FFB74D, #FFCC80);
}

.mini-count {
  font-size: 22rpx;
  color: #BCAAA4;
  margin-bottom: 8rpx;
}

.mini-status {
  font-size: 22rpx;
  color: #E8905C;
  font-weight: 500;
}

.mini-card.checked .mini-status {
  color: #E8905C;
}

.mini-card.done .mini-status {
  color: #BF8C4A;
}

.mini-detail-tag {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  font-size: 18rpx;
  color: #E8905C;
  background: #FFF2EC;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

/* Paw print decoration (appears on checked cards) */
.paw-print {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 32rpx;
  height: 28rpx;
  opacity: 0.5;
}

.paw-pad {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 10rpx;
  background: #E8905C;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
}

.paw-toe {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #E8905C;
  border-radius: 50%;
  top: 0;
}

.paw-toe-1 { left: 0; }
.paw-toe-2 { left: 50%; transform: translateX(-50%); }
.paw-toe-3 { right: 0; }

/* Empty strip */
.strip-empty {
  text-align: center;
  padding: 44rpx 0 24rpx;
}

.strip-empty-emoji {
  display: block;
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.strip-empty-text {
  display: block;
  font-size: 26rpx;
  color: #BCAAA4;
  margin-bottom: 4rpx;
}

.strip-empty-hint {
  font-size: 22rpx;
  color: #C9BFB5;
}

/* ====== Management Card ====== */

.manage-card {
  background: #FFFBF7;
  border-radius: 28rpx;
  padding: 28rpx 20rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(180,140,120,0.08);
}

.manage-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
  padding: 0 8rpx;
}

.manage-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5D4037;
}

.new-btn {
  font-size: 24rpx;
  background: #E8905C;
  color: #fff;
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-weight: 500;
  min-width: unset;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* ====== Task Row ====== */

.task-row {
  margin-bottom: 4rpx;
}

.task-row.expired {
  opacity: 0.45;
}

.task-row-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  border-bottom: 1rpx solid #F5F0EB;
}

.task-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.task-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.task-body {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.task-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 4rpx;
}

.task-meta {
  font-size: 22rpx;
  color: #BCAAA4;
}

.task-actions {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 24rpx;
  color: #E8905C;
  padding: 0 16rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 16rpx;
  min-width: unset;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.action-btn.danger {
  color: #D4804A;
}

/* ====== Inline Form ====== */

.inline-form {
  padding: 20rpx 10rpx;
  border-bottom: 1rpx solid #F5F0EB;
  background: linear-gradient(180deg, #FFFBF7 0%, #FFF5EC 100%);
  border-radius: 16rpx;
  margin-bottom: 4rpx;
}

.form-item {
  margin-bottom: 18rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #8D7B72;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  height: 72rpx;
  background: #FFFBF7;
  border-radius: 16rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #5D4037;
  box-sizing: border-box;
  border: 2rpx solid #F0E8E0;
}

.form-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.form-half {
  flex: 1;
}

.switch-row {
  display: flex;
  flex-direction: column;
}

.switch-row .form-label {
  margin-bottom: 12rpx;
}

.picker-val {
  height: 72rpx;
  background: #FFFBF7;
  border-radius: 16rpx;
  padding: 0 16rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #5D4037;
  border: 2rpx solid #F0E8E0;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.emoji-cell {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  background: #FFFBF7;
  border-radius: 14rpx;
  border: 2rpx solid #F0E8E0;
  transition: all 0.15s;
}

.emoji-cell.selected {
  border-color: #E8905C;
  background: #FFF2EC;
  transform: scale(1.1);
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 22rpx;
}

.form-actions button[type="primary"] {
  font-size: 24rpx;
  min-width: unset;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
}

.cancel-btn {
  font-size: 24rpx;
  background: #F5F0EB;
  color: #8D7B72;
  border-radius: 24rpx;
  min-width: unset;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* ====== Empty State ====== */

.empty {
  text-align: center;
  color: #BCAAA4;
  padding: 48rpx 0;
}

.empty-emoji {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  display: block;
  font-size: 22rpx;
  color: #C9BFB5;
  margin-top: 6rpx;
}

/* Celebration Canvas */
.celebration-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 999;
  pointer-events: none;
}
