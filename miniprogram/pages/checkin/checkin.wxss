.page {
  padding: 20rpx;
}

.task-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.task-card {
  background: #FFFBF7;
  border-radius: 20rpx;
  padding: 34rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(180,140,120,0.10);
  transition: transform 0.15s;
}

.task-card:active {
  transform: scale(0.96);
}

.card-emoji {
  font-size: 68rpx;
  margin-bottom: 14rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #5D4037;
}

.card-count {
  font-size: 24rpx;
  color: #BCAAA4;
  margin-bottom: 8rpx;
}

.card-status {
  font-size: 22rpx;
  color: #FF8A80;
}

.task-card.expired {
  opacity: 0.45;
  background: #F5F0EB;
}

.task-card.expired .card-status {
  color: #BCAAA4;
}

.task-card.not-started {
  border: 2rpx dashed #E0D5CC;
}

.task-card.not-started .card-status {
  color: #C9BFB5;
}

.task-card.checked {
  background: #FFF0ED;
}

.task-card.checked .card-status {
  color: #FF8A80;
  font-weight: 600;
}

.card-detail-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 20rpx;
  color: #FF8A80;
  background: #FFF0ED;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.empty {
  text-align: center;
  color: #BCAAA4;
  margin-top: 200rpx;
}
