.page {
  padding: 20rpx;
}

.task-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.task-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}

.task-card:active {
  transform: scale(0.96);
}

.card-emoji {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.card-count {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.card-status {
  font-size: 22rpx;
  color: #07C160;
}

.task-card.expired {
  opacity: 0.5;
  background: #f5f5f5;
}

.task-card.expired .card-status {
  color: #999;
}

.task-card.not-started {
  border: 1rpx dashed #ddd;
}

.task-card.not-started .card-status {
  color: #bbb;
}

.task-card.checked {
  background: #eafaf1;
}

.task-card.checked .card-status {
  color: #07C160;
  font-weight: 500;
}

.card-detail-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 20rpx;
  color: #07C160;
  background: #eafaf1;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.empty {
  text-align: center;
  color: #888;
  margin-top: 200rpx;
}
