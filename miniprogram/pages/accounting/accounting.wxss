.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FFF5EC;
  position: relative;
  box-sizing: border-box;
}

/* ======== Top Bar ======== */
.top-bar {
  background: #FFFBF7;
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
  z-index: 10;
  padding: 16rpx 24rpx 14rpx;
}

.top-row1 {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #5D4037;
  padding: 4rpx 0 12rpx;
}

.ledger-arrow {
  font-size: 18rpx;
  color: #BCAAA4;
}

.top-row2 {
  display: flex;
  align-items: center;
}

.month-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.2;
  width: 140rpx;
  flex-shrink: 0;
}

.mp-year {
  font-size: 24rpx;
  color: #BCAAA4;
  font-weight: 400;
}

.mp-month {
  font-size: 34rpx;
  color: #5D4037;
  font-weight: 700;
}

.summary {
  display: flex;
  flex: 1;
  justify-content: space-around;
  padding-left: 16rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #8D7B72;
  font-weight: 500;
}

.summary-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #5D4037;
  white-space: nowrap;
}

.summary-value.income {
  color: #2E7D32;
}

.summary-value.expense {
  color: #C62828;
}

/* ======== Transaction List ======== */
.tx-list {
  flex: 1;
  height: 0;
  padding: 16rpx 20rpx;
}

.list-bottom {
  height: 160rpx;
}

/* Date Group */
.date-group {
  margin-bottom: 32rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 14rpx;
  padding: 0 20rpx 0 8rpx;
}

.date-left {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.date-dot {
  width: 10rpx;
  height: 10rpx;
  background: #E8905C;
  border-radius: 50%;
  flex-shrink: 0;
  align-self: center;
}

.date-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #5D4037;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.date-weekday {
  font-size: 22rpx;
  color: #BCAAA4;
  flex-shrink: 0;
}

.date-summary {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  padding: 0 20rpx 0 8rpx;
}

.day-income {
  color: #2E7D32;
  white-space: nowrap;
}

.day-expense {
  color: #C62828;
  white-space: nowrap;
}

/* Transaction Card */
.tx-card {
  background: #FFFBF7;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(180,140,120,0.06);
}

.tx-row {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #F5F0EB;
  gap: 10rpx;
}

.tx-row:last-child {
  border-bottom: none;
}

.tx-row:active {
  background: #FFF5EC;
}

.tx-emoji {
  font-size: 38rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}

.tx-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.tx-category {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 600;
}

.tx-desc {
  font-size: 24rpx;
  color: #BCAAA4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-divider {
  width: 1rpx;
  height: 36rpx;
  background: #E0D5CC;
  flex-shrink: 0;
}

.tx-amount {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
  padding: 8rpx 0 8rpx 12rpx;
  min-width: 150rpx;
  text-align: left;
  box-sizing: border-box;
}

.tx-amount.income {
  color: #2E7D32;
}

.tx-amount.expense {
  color: #C62828;
}

/* ======== FAB Group ======== */
.fab-group {
  position: fixed;
  bottom: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  z-index: 20;
  pointer-events: none;
}

.fab {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(232,144,92,0.4);
  pointer-events: auto;
}

.fab:active {
  transform: scale(0.92);
  transition: transform 0.15s;
}

.fab-add {
  background: #E8905C;
}

.fab-add text {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
}

.fab-stats {
  background: #FFFBF7;
  border: 2rpx solid #E8905C;
}

.fab-icon {
  font-size: 40rpx;
  line-height: 1;
}

/* ======== Empty State ======== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #BCAAA4;
  display: block;
}

.empty-hint {
  font-size: 24rpx;
  color: #C9BFB5;
  margin-top: 8rpx;
  display: block;
}

/* ======== Loading ======== */
.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #BCAAA4;
}

/* ======== Sheet Overlay (shared) ======== */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ======== Detail Bottom Sheet ======== */
.sheet-content {
  width: 100%;
  background: #FFFBF7;
  border-radius: 28rpx 28rpx 0 0;
  padding: 0 28rpx 40rpx;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #E0D5CC;
  border-radius: 3rpx;
  margin: 16rpx auto 24rpx;
}

.detail-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.detail-emoji {
  font-size: 52rpx;
  flex-shrink: 0;
}

.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-category {
  font-size: 32rpx;
  font-weight: 700;
  color: #5D4037;
}

.detail-desc {
  font-size: 26rpx;
  color: #8D7B72;
}

.detail-date {
  font-size: 22rpx;
  color: #BCAAA4;
}

.detail-amount {
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 14rpx;
  border: 2rpx solid #F0E8E0;
}

.detail-amount.income {
  color: #2E7D32;
  border-color: #C8E6C9;
}

.detail-amount.expense {
  color: #C62828;
  border-color: #FFCDD2;
}

.sheet-actions {
  display: flex;
  gap: 16rpx;
}

.sheet-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.sheet-btn.edit {
  background: #FFF2EC;
  color: #E8905C;
}

.sheet-btn.delete {
  background: #F5F0EB;
  color: #D4804A;
}

.sheet-btn:active {
  opacity: 0.8;
}

/* ======== Ledger Picker ======== */
.picker-content {
  width: 100%;
  background: #FFFBF7;
  border-radius: 28rpx 28rpx 0 0;
  padding: 0 28rpx 40rpx;
  animation: slideUp 0.25s ease-out;
}

.picker-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #5D4037;
  padding: 28rpx 0 20rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 16rpx;
  font-size: 28rpx;
  color: #5D4037;
  border-radius: 16rpx;
  margin-bottom: 4rpx;
}

.picker-item.active {
  background: #FFF2EC;
  color: #E8905C;
  font-weight: 600;
}

.picker-item:active {
  background: #FFF5EC;
}

.check-mark {
  color: #E8905C;
  font-weight: 700;
}

.picker-footer {
  text-align: center;
  padding: 22rpx 0 8rpx;
  font-size: 28rpx;
  color: #E8905C;
  font-weight: 600;
  border-top: 1rpx solid #F5F0EB;
  margin-top: 8rpx;
}

/* ======== New Ledger Form ======== */
.form-content {
  width: 100%;
  background: #FFFBF7;
  border-radius: 28rpx 28rpx 0 0;
  padding: 0 28rpx 40rpx;
  animation: slideUp 0.25s ease-out;
}

.form-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #5D4037;
  padding: 28rpx 0 20rpx;
}

.form-input {
  height: 72rpx;
  background: #FFFBF7;
  border-radius: 16rpx;
  border: 2rpx solid #F0E8E0;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #5D4037;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8D7B72;
  margin-bottom: 12rpx;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.emoji-cell {
  width: 62rpx;
  height: 62rpx;
  font-size: 34rpx;
  background: #FFFBF7;
  border-radius: 14rpx;
  border: 2rpx solid #F0E8E0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emoji-cell.selected {
  border-color: #E8905C;
  background: #FFF2EC;
  transform: scale(1.1);
}

.form-actions {
  display: flex;
  gap: 16rpx;
}

.form-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.form-btn.cancel {
  background: #F5F0EB;
  color: #8D7B72;
}

.form-btn.confirm {
  background: #E8905C;
  color: #fff;
}

.form-btn:active {
  opacity: 0.8;
}
