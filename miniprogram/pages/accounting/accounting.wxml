<view class="page">
  <!-- Top Bar -->
  <view class="top-bar">
    <view class="top-row1" bindtap="toggleLedgerPicker">
      <text>{{currentLedger.emoji}} {{currentLedger.name}}</text>
      <text class="ledger-arrow">▼</text>
    </view>
    <view class="top-row2">
      <picker mode="date" fields="month" value="{{monthKey}}" bindchange="selectMonth">
        <view class="month-picker">{{monthDisplay}} ▼</view>
      </picker>
      <view class="summary">
        <view class="summary-item">
          <text class="summary-label">收</text>
          <text class="summary-value income">{{monthlyIncome}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">支</text>
          <text class="summary-value expense">{{monthlyExpense}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">余</text>
          <text class="summary-value">{{monthlyBalance}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Transaction List -->
  <scroll-view scroll-y class="tx-list" wx:if="{{!loading}}">
    <view wx:if="{{groupedTransactions.length === 0}}" class="empty">
      <text class="empty-emoji">📝</text>
      <text class="empty-text">本月暂无记录</text>
      <text class="empty-hint">点击右下角 + 开始记账吧</text>
    </view>

    <view class="date-group" wx:for="{{groupedTransactions}}" wx:key="date">
      <view class="date-header">
        <view class="date-left">
          <view class="date-dot"></view>
          <text class="date-text">{{item.date}}</text>
          <text class="date-weekday">{{item.weekday}}</text>
        </view>
        <view class="date-summary">
          <text wx:if="{{item.dayIncome > 0}}" class="day-income">收 {{item.dayIncome}}</text>
          <text wx:if="{{item.dayExpense > 0}}" class="day-expense">支 {{item.dayExpense}}</text>
        </view>
      </view>

      <view class="tx-card">
        <view
          class="tx-row"
          wx:for="{{item.transactions}}"
          wx:for-item="tx"
          wx:key="_id"
          data-id="{{tx._id}}"
          bindtap="showDetail"
        >
          <text class="tx-emoji">{{tx.categoryEmoji}}</text>
          <view class="tx-info">
            <text class="tx-category">{{tx.category}}</text>
            <text wx:if="{{tx.description}}" class="tx-desc">{{tx.description}}</text>
          </view>
          <text class="tx-amount {{tx.type}}">{{tx.type === 'income' ? '+' : '-'}}{{tx.amount}}</text>
        </view>
      </view>
    </view>

    <view class="list-bottom"></view>
  </scroll-view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="goAdd">
    <text>+</text>
  </view>

  <!-- Detail Bottom Sheet -->
  <view class="sheet-overlay" wx:if="{{showDetail}}" bindtap="hideDetail">
    <view class="sheet-content" catchtap>
      <view class="sheet-handle"></view>
      <view class="detail-header">
        <text class="detail-emoji">{{detailTx.categoryEmoji}}</text>
        <view class="detail-info">
          <text class="detail-category">{{detailTx.category}}</text>
          <text wx:if="{{detailTx.description}}" class="detail-desc">{{detailTx.description}}</text>
          <text class="detail-date">{{detailTx.date}}</text>
        </view>
        <text class="detail-amount {{detailTx.type}}">{{detailTx.type === 'income' ? '+' : '-'}}{{detailTx.amount}}</text>
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn edit" bindtap="editTransaction">编辑</view>
        <view class="sheet-btn delete" bindtap="deleteTransaction">删除</view>
      </view>
    </view>
  </view>

  <!-- Ledger Picker Overlay -->
  <view class="sheet-overlay" wx:if="{{showLedgerPicker}}" bindtap="toggleLedgerPicker">
    <view class="picker-content" catchtap>
      <view class="picker-title">切换账本</view>
      <view
        class="picker-item {{currentLedger._id === item._id ? 'active' : ''}}"
        wx:for="{{ledgers}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="switchLedger"
      >
        <text>{{item.emoji}} {{item.name}}</text>
        <text wx:if="{{currentLedger._id === item._id}}" class="check-mark">✓</text>
      </view>
      <view class="picker-footer" bindtap="openLedgerForm">
        <text>+ 新建账本</text>
      </view>
    </view>
  </view>

  <!-- New Ledger Form Overlay -->
  <view class="sheet-overlay" wx:if="{{showLedgerForm}}" bindtap="closeLedgerForm">
    <view class="form-content" catchtap>
      <view class="form-title">新建账本</view>
      <input
        class="form-input"
        placeholder="账本名称"
        value="{{newLedgerName}}"
        bindinput="onLedgerNameInput"
        maxlength="10"
      />
      <view class="form-label">选择图标</view>
      <view class="emoji-grid">
        <view
          class="emoji-cell {{newLedgerEmoji === item ? 'selected' : ''}}"
          wx:for="{{ledgerEmojis}}"
          wx:key="*this"
          data-emoji="{{item}}"
          bindtap="selectLedgerEmoji"
        >{{item}}</view>
      </view>
      <view class="form-actions">
        <view class="form-btn cancel" bindtap="closeLedgerForm">取消</view>
        <view class="form-btn confirm" bindtap="createLedger">创建</view>
      </view>
    </view>
  </view>
</view>
