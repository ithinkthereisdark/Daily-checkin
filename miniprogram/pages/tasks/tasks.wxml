<view class="page">

  <!-- Task list -->
  <block wx:if="{{!showForm}}">
    <view class="header">
      <text class="header-title">我的任务</text>
      <button class="add-btn" type="primary" size="mini" bindtap="openCreateForm">新建</button>
    </view>

    <view wx:if="{{tasks.length === 0}}" class="empty">还没有任务，点击「新建」创建一个吧</view>

    <block wx:for="{{tasks}}" wx:key="_id">
      <view class="task-item">
        <view class="task-info">
          <text class="task-emoji">{{item.emoji}}</text>
          <view class="task-body">
            <text class="task-name">{{item.name}}</text>
            <text class="task-meta">{{item.startDate}} ~ {{item.endDate}} · 目标 {{item.targetCount}} 次 · {{item.needDetail ? '需详细记录' : '快速打卡'}}</text>
          </view>
        </view>
        <view class="task-actions">
          <button class="action-btn" size="mini" bindtap="openEditForm" data-index="{{index}}">编辑</button>
          <button class="action-btn danger" size="mini" bindtap="deleteTask" data-index="{{index}}">删除</button>
        </view>
      </view>
    </block>
  </block>

  <!-- Form -->
  <block wx:if="{{showForm}}">
    <view class="header">
      <text class="header-title">{{formIndex >= 0 ? '编辑任务' : '新建任务'}}</text>
      <button class="cancel-btn" size="mini" bindtap="cancelForm">取消</button>
    </view>

    <view class="form">
      <view class="form-item">
        <text class="label">名称</text>
        <input class="input" value="{{formData.name}}" bindinput="onNameInput" placeholder="任务名称" maxlength="20"/>
      </view>

      <view class="form-item">
        <text class="label">图标</text>
        <view class="emoji-grid">
          <block wx:for="{{emojiList}}" wx:key="*this">
            <view class="emoji-cell {{formData.emoji === item ? 'selected' : ''}}" data-emoji="{{item}}" bindtap="selectEmoji">{{item}}</view>
          </block>
        </view>
      </view>

      <view class="form-item">
        <text class="label">开始日期</text>
        <picker mode="date" value="{{formData.startDate}}" bindchange="onStartDateChange">
          <view class="picker-val">{{formData.startDate || '请选择'}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">结束日期</text>
        <picker mode="date" value="{{formData.endDate}}" bindchange="onEndDateChange">
          <view class="picker-val">{{formData.endDate || '请选择'}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">目标次数</text>
        <input class="input" type="number" value="{{formData.targetCount}}" bindinput="onTargetInput" placeholder="目标打卡次数"/>
      </view>

      <view class="form-item row">
        <text class="label">需要详细记录</text>
        <switch checked="{{formData.needDetail}}" bindchange="toggleNeedDetail"/>
      </view>

      <button type="primary" bindtap="submitForm">{{formIndex >= 0 ? '保存' : '创建'}}</button>
    </view>
  </block>

</view>
