.page {
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #5D4037;
}

.empty {
  text-align: center;
  color: #BCAAA4;
  margin-top: 200rpx;
}

.task-item {
  background: #FFFBF7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
}

.task-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.task-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.task-body {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.task-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  color: #5D4037;
}

.task-meta {
  font-size: 22rpx;
  color: #BCAAA4;
}

.task-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  color: #FF8A80;
}

.action-btn.danger {
  color: #E57373;
}

.add-btn {
  font-size: 24rpx;
  background: #FF8A80;
  color: #fff;
}

.cancel-btn {
  font-size: 24rpx;
  background: #F5F0EB;
  color: #8D7B72;
}

.form {
  padding-top: 10rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #8D7B72;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #FFFBF7;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #5D4037;
  box-sizing: border-box;
  border: 2rpx solid #F0E8E0;
}

.picker-val {
  height: 80rpx;
  background: #FFFBF7;
  border-radius: 14rpx;
  padding: 0 20rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #5D4037;
  border: 2rpx solid #F0E8E0;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.emoji-cell {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  background: #FFFBF7;
  border-radius: 14rpx;
  border: 2rpx solid #F0E8E0;
}

.emoji-cell.selected {
  border-color: #FF8A80;
  background: #FFF0ED;
}
