.page {
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.empty {
  text-align: center;
  color: #888;
  margin-top: 200rpx;
}

.task-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.task-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.task-body {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.task-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.task-meta {
  font-size: 22rpx;
  color: #999;
}

.task-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 22rpx;
}

.action-btn.danger {
  color: #e74c3c;
}

.add-btn {
  font-size: 24rpx;
}

.cancel-btn {
  font-size: 24rpx;
  background: #eee;
}

.form {
  padding-top: 10rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #555;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-val {
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.emoji-cell {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.emoji-cell.selected {
  border-color: #07C160;
  background: #eafaf1;
}
