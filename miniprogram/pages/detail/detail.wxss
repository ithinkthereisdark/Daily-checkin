.page {
  padding: 30rpx;
}

/* ====== Task Header ====== */

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  background: #FFFBF7;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(180,140,120,0.06);
}

.task-emoji {
  font-size: 56rpx;
  margin-right: 18rpx;
}

.task-title-group {
  display: flex;
  flex-direction: column;
}

.task-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #5D4037;
  margin-bottom: 4rpx;
}

.task-hint {
  font-size: 24rpx;
  color: #BCAAA4;
}

/* ====== Notice Banner ====== */

.notice {
  background: #FFF8E1;
  color: #BF8C4A;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.notice-emoji {
  margin-right: 10rpx;
  font-size: 28rpx;
}

/* ====== Form ====== */

.desc-input {
  width: 100%;
  min-height: 260rpx;
  background: #FFFBF7;
  border-radius: 18rpx;
  padding: 22rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  line-height: 1.6;
  color: #5D4037;
  border: 2rpx solid #F0E8E0;
  box-shadow: 0 2rpx 10rpx rgba(180,140,120,0.04);
}

.image-area {
  margin-top: 30rpx;
  text-align: center;
}

.preview-img {
  width: 100%;
  height: 380rpx;
  border-radius: 18rpx;
  background: #F5F0EB;
}

.img-tip {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #BCAAA4;
}

.btn-group {
  margin-top: 30rpx;
}

.img-btn {
  width: 100%;
  color: #8D7B72;
  background: #FFFBF7;
  border: 2rpx solid #E0D5CC;
  border-radius: 18rpx;
  font-size: 28rpx;
}
