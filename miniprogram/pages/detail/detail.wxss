.page {
  padding: 30rpx;
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-emoji {
  font-size: 52rpx;
  margin-right: 16rpx;
}

.task-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #5D4037;
}

.notice {
  background: #FFF8E1;
  color: #BF8C4A;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  margin-bottom: 24rpx;
}

.desc-input {
  width: 100%;
  min-height: 240rpx;
  background: #FFFBF7;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  line-height: 1.6;
  color: #5D4037;
  border: 2rpx solid #F0E8E0;
}

.image-area {
  margin-top: 30rpx;
  text-align: center;
}

.preview-img {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background: #F5F0EB;
}

.img-tip {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #BCAAA4;
}

.btn-group {
  margin-top: 30rpx;
}

.img-btn {
  width: 100%;
  color: #8D7B72;
  background: #FFFBF7;
  border: 2rpx solid #E0D5CC;
  border-radius: 14rpx;
}
