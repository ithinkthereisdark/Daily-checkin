.page {
  padding: 20rpx;
}

/* ====== Date Group ====== */

.date-group {
  margin-bottom: 40rpx;
}

.date-header {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding-left: 4rpx;
}

.date-dot {
  width: 12rpx;
  height: 12rpx;
  background: #E8905C;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
  margin-right: 10rpx;
  color: #5D4037;
}

.date-weekday {
  font-size: 24rpx;
  color: #BCAAA4;
}

/* Tiny paw decoration next to date */
.date-paw {
  position: relative;
  width: 20rpx;
  height: 16rpx;
  margin-left: auto;
  opacity: 0.3;
}

.dp-toe {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #E8905C;
  border-radius: 50%;
  top: 0;
}

.dp-toe:nth-child(1) { left: 0; }
.dp-toe:nth-child(2) { left: 50%; transform: translateX(-50%); }
.dp-toe:nth-child(3) { right: 0; }

.dp-pad {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 7rpx;
  background: #E8905C;
  border-radius: 6rpx 6rpx 3rpx 3rpx;
}

/* ====== Check-in List ====== */

.checkin-list {
  background: #FFFBF7;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(180,140,120,0.06);
}

.checkin-item {
  display: flex;
  align-items: flex-start;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #F5F0EB;
  position: relative;
}

.checkin-item:last-child {
  border-bottom: none;
}

.item-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
}

.item-desc {
  font-size: 26rpx;
  color: #8D7B72;
  margin-top: 8rpx;
  line-height: 1.5;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 14rpx;
  margin-top: 14rpx;
  background: #F5F0EB;
}

/* Decorative tail dots */
.item-tail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
  align-self: center;
  opacity: 0.25;
}

.tail-dot {
  width: 6rpx;
  height: 6rpx;
  background: #E8905C;
  border-radius: 50%;
}

/* ====== Empty State ====== */

.empty {
  text-align: center;
  margin-top: 200rpx;
}

.empty-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #BCAAA4;
  margin-bottom: 6rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #C9BFB5;
}

/* ====== View Toggle ====== */
.view-toggle {
  display: flex;
  background: #FFFBF7;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
}

.toggle-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #8D7B72;
  background: #FFFBF7;
}

.toggle-tab.active {
  background: #E8905C;
  color: #fff;
}

/* ====== Month View ====== */
.month-view {
  background: #FFFBF7;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 14rpx rgba(180,140,120,0.06);
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 20rpx;
}

.month-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #E8905C;
  background: #FFF2EC;
  border-radius: 50%;
}

.month-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #5D4037;
}

.weekday-row {
  display: flex;
  margin-bottom: 4rpx;
}

.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #BCAAA4;
  padding: 4rpx 0;
}

.calendar-grid {
  display: flex;
  flex-direction: column;
}

.cal-row {
  display: flex;
  margin-bottom: 4rpx;
}

.cal-row:last-child {
  margin-bottom: 0;
}

.cal-cell {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #F5F0EB;
  margin-right: 4rpx;
}

.cal-cell:last-child {
  margin-right: 0;
}

.cal-cell.empty {
  background: transparent;
}

.cal-cell.partial {
  background: rgba(232,144,92,0.35);
}

.cal-cell.all {
  background: #E8905C;
}

.cal-cell.all .cal-day {
  color: #fff;
  font-weight: 700;
}

.cal-cell.today {
  border: 2rpx solid #E8905C;
}

.cal-cell.future {
  opacity: 0.35;
}

.cal-cell.selected {
  border: 3rpx solid #E8905C;
  transform: scale(1.05);
}

.cal-day {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
}

.cal-detail {
  margin-top: 24rpx;
  border-top: 1rpx solid #F5F0EB;
  padding-top: 20rpx;
}

.cal-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 0 8rpx;
  margin-bottom: 12rpx;
}

.cal-detail-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #5D4037;
}

.cal-detail-count {
  font-size: 22rpx;
  color: #BCAAA4;
}

.cal-detail-empty {
  text-align: center;
  color: #BCAAA4;
  font-size: 24rpx;
  padding: 30rpx 0;
}
