.page {
  padding: 20rpx;
}

.date-group {
  margin-bottom: 32rpx;
}

.date-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

.date-weekday {
  font-size: 24rpx;
  color: #999;
}

.checkin-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.checkin-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.checkin-item:last-child {
  border-bottom: none;
}

.item-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
}

.item-desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.5;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  margin-top: 12rpx;
  background: #eee;
}

.empty {
  text-align: center;
  color: #888;
  margin-top: 200rpx;
}
