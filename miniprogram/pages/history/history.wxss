.page {
  padding: 20rpx;
}

/* ====== Date Group ====== */

.date-group {
  margin-bottom: 40rpx;
}

.date-header {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding-left: 4rpx;
}

.date-dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF8A80;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
  margin-right: 10rpx;
  color: #5D4037;
}

.date-weekday {
  font-size: 24rpx;
  color: #BCAAA4;
}

/* Tiny paw decoration next to date */
.date-paw {
  position: relative;
  width: 20rpx;
  height: 16rpx;
  margin-left: auto;
  opacity: 0.3;
}

.dp-toe {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #FF8A80;
  border-radius: 50%;
  top: 0;
}

.dp-toe:nth-child(1) { left: 0; }
.dp-toe:nth-child(2) { left: 50%; transform: translateX(-50%); }
.dp-toe:nth-child(3) { right: 0; }

.dp-pad {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 7rpx;
  background: #FF8A80;
  border-radius: 6rpx 6rpx 3rpx 3rpx;
}

/* ====== Check-in List ====== */

.checkin-list {
  background: #FFFBF7;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(180,140,120,0.06);
}

.checkin-item {
  display: flex;
  align-items: flex-start;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #F5F0EB;
  position: relative;
}

.checkin-item:last-child {
  border-bottom: none;
}

.item-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
}

.item-desc {
  font-size: 26rpx;
  color: #8D7B72;
  margin-top: 8rpx;
  line-height: 1.5;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 14rpx;
  margin-top: 14rpx;
  background: #F5F0EB;
}

/* Decorative tail dots */
.item-tail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
  align-self: center;
  opacity: 0.25;
}

.tail-dot {
  width: 6rpx;
  height: 6rpx;
  background: #FF8A80;
  border-radius: 50%;
}

/* ====== Empty State ====== */

.empty {
  text-align: center;
  margin-top: 200rpx;
}

.empty-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #BCAAA4;
  margin-bottom: 6rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #C9BFB5;
}
