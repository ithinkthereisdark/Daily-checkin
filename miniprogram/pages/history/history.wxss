.page {
  padding: 20rpx;
}

.date-group {
  margin-bottom: 36rpx;
}

.date-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 18rpx;
  padding-left: 8rpx;
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
  margin-right: 12rpx;
  color: #5D4037;
}

.date-weekday {
  font-size: 24rpx;
  color: #BCAAA4;
}

.checkin-list {
  background: #FFFBF7;
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
}

.checkin-item {
  display: flex;
  align-items: flex-start;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #F5F0EB;
}

.checkin-item:last-child {
  border-bottom: none;
}

.item-emoji {
  font-size: 42rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
}

.item-desc {
  font-size: 26rpx;
  color: #8D7B72;
  margin-top: 8rpx;
  line-height: 1.5;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
  background: #F5F0EB;
}

.empty {
  text-align: center;
  color: #BCAAA4;
  margin-top: 200rpx;
}
