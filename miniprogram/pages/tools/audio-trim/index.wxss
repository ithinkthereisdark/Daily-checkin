.page {
  padding: 20rpx;
}

/* ====== Upload Zone (idle) ====== */

.upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 480rpx;
  background: #FFFBF7;
  border-radius: 28rpx;
  border: 3rpx dashed #E0D5CC;
  box-shadow: 0 4rpx 20rpx rgba(180,140,120,0.06);
  margin-top: 40rpx;
}

.upload-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.upload-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #5D4037;
  margin-bottom: 10rpx;
}

.upload-hint {
  font-size: 26rpx;
  color: #BCAAA4;
  margin-bottom: 8rpx;
}

.upload-formats {
  font-size: 22rpx;
  color: #C9BFB5;
}

/* ====== Audio Info Bar ====== */

.audio-info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFBF7;
  border-radius: 22rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
}

.audio-file-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 1;
}

.audio-filename {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.audio-duration {
  font-size: 22rpx;
  color: #BCAAA4;
}

.change-file-btn {
  font-size: 24rpx;
  background: #F5F0EB;
  color: #8D7B72;
  border-radius: 20rpx;
  min-width: unset;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ====== Playback Card ====== */

.playback-card {
  background: #FFFBF7;
  border-radius: 22rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
}

.playback-row {
  display: flex;
  align-items: center;
}

.play-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8905C;
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: unset;
  padding: 0;
  line-height: 72rpx;
  border: none;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.play-btn.playing {
  background: #D4804A;
}

.play-btn::after {
  border: none;
}

.time-and-progress {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.current-time-display {
  font-size: 26rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 6rpx;
}

.progress-wrap {
  width: 100%;
}

.progress-wrap slider {
  width: 100%;
}

/* ====== Trim Card ====== */

.trim-card {
  background: #FFFBF7;
  border-radius: 22rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(180,140,120,0.06);
}

.trim-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 14rpx;
}

.trim-range-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
  padding: 14rpx 18rpx;
  background: #F5F0EB;
  border-radius: 14rpx;
}

.trim-range-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
}

.trim-length-text {
  font-size: 22rpx;
  color: #BF8C4A;
}

/* Sliders */

.slider-group {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.slider-label {
  width: 56rpx;
  font-size: 26rpx;
  color: #8D7B72;
  flex-shrink: 0;
}

.slider-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.slider-wrap slider {
  flex: 1;
}

.slider-val {
  width: 80rpx;
  text-align: right;
  font-size: 24rpx;
  color: #BCAAA4;
  flex-shrink: 0;
}

/* Preview Button */

.preview-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #E8905C;
  background: #FFF2EC;
  border-radius: 22rpx;
  margin-top: 10rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-btn::after {
  border: none;
}

/* ====== Action Card ====== */

.action-card {
  margin-bottom: 18rpx;
}

.trim-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: #E8905C;
  border-radius: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trim-btn::after {
  border: none;
}

/* ====== Result Card ====== */

.result-card {
  background: #FFFBF7;
  border-radius: 22rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(180,140,120,0.08);
  border: 2rpx solid #FFE0B2;
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #5D4037;
  text-align: center;
  margin-bottom: 22rpx;
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.play-result-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #E8905C;
  background: #FFF2EC;
  border-radius: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-result-btn.playing {
  background: #E8905C;
  color: #fff;
}

.play-result-btn::after {
  border: none;
}

.save-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #fff;
  background: #E8905C;
  border-radius: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  border: none;
}
