.page {
  padding: 20rpx;
}

/* ====== Header ====== */

.tools-header {
  text-align: center;
  padding: 36rpx 0 28rpx;
}

.tools-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #5D4037;
  margin-bottom: 8rpx;
}

.tools-sub {
  display: block;
  font-size: 26rpx;
  color: #BCAAA4;
}

/* ====== Tool Cards ====== */

.tools-list {
  margin-bottom: 24rpx;
}

.tool-card {
  display: flex;
  align-items: center;
  background: #FFFBF7;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(180,140,120,0.08);
  transition: transform 0.15s;
}

.tool-card-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(180,140,120,0.12);
}

.tool-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #F5F0EB;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tool-icon {
  font-size: 44rpx;
}

.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 6rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #BCAAA4;
}

.tool-arrow {
  font-size: 40rpx;
  color: #C9BFB5;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ====== Footer ====== */

.tools-footer {
  text-align: center;
  padding: 36rpx 0;
}

.footer-hint {
  font-size: 24rpx;
  color: #C9BFB5;
}
